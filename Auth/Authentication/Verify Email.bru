meta {
  name: Verify Email
  type: http
  seq: 2
}

post {
  url: {{baseIP_url}}/v1/auth/verify
  body: multipartForm
  auth: inherit
}

headers {
  Accept: application/json
}

body:multipart-form {
  email: omaradmin@yopmail.com
  otp: 938909
}

settings {
  encodeUrl: true
  timeout: 0
}

docs {
  Verifies a user's account with the OTP or token sent to their email and logs them in.
}
