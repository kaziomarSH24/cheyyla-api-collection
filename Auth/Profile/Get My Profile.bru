meta {
  name: Get My Profile
  type: http
  seq: 1
}

get {
  url: {{base_url}}/v1/profile/me
  body: none
  auth: bearer
}

headers {
  Accept: application/json
  Authorization: Bearer {{auth_token}}
}

auth:bearer {
  token: {{adminToken}}
}

vars:pre-request {
  base_url: http://10.10.10.55:60/api
}

settings {
  encodeUrl: true
  timeout: 0
}

docs {
  Gets all information (including roles and permissions) for the logged-in user.
}
