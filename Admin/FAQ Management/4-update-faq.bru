meta {
  name: Update FAQ
  type: http
  seq: 4
}

put {
  url: {{baseIP_url}}/v1/admin/faqs/1
  body: json
  auth: bearer
}

auth:bearer {
  token: {{adminToken}}
}

body:json {
  {
    "question": "What is your updated return policy?",
    "answer": "You can return items within 14 days of delivery.",
    "is_active": true
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
