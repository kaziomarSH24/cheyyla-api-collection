meta {
  name: Refund
  type: http
  seq: 4
}

post {
  url: {{baseIP_url}}/v1/admin/orders/:orderId/refund
  body: multipartForm
  auth: bearer
}

params:path {
  orderId: 20
}

auth:bearer {
  token: {{adminToken}}
}

body:json {
  {
    "amount": 50
  }
}

body:multipart-form {
  amount: 25 @contentType(if not provide any it will be fully refund )
}

settings {
  encodeUrl: true
  timeout: 0
}
