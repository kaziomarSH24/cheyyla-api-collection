meta {
  name: Update Category
  type: http
  seq: 1
}

put {
  url: {{baseIP_url}}/v1/categories/:categoryId
  body: multipartForm
  auth: bearer
}

params:path {
  categoryId: 3
}

auth:bearer {
  token: {{adminToken}}
}

body:multipart-form {
  name: lunch
  image: @file(C:\Users\kazio\OneDrive\Pictures\image_2.jpg)
}

settings {
  encodeUrl: true
  timeout: 0
}
